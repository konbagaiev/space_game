# Dependencies
node_modules/

# Server data (legacy local dir; unused now that storage is Postgres)
server/data/

# Builds
dist/
build/

# Visual-test artifacts (screenshots are for review, not committed)
client/visual/__screenshots__/

# Heavy / source 3D assets — keep OUT of git (too big for a web game + they bloat history forever).
# Commit only web-optimized .glb (KB to ~1-2 MB). Put heavy originals in an _source/ folder, or use
# Git LFS if you truly must version them.
client/assets/**/_source/
client/assets/ships/*_4k.glb
client/assets/ships/spaceship_colaid1_50k.glb

# Ship-model asset pipeline (docs/plans/ship-model-pipeline.md): NO binaries in git — S3 is canonical.
# (gitignore has no inline comments — keep each pattern on its own line.)
# high-poly source originals (scratch staging; canonical copy on S3 source/)
assets-src/
# build outputs (uploaded to S3 by assets:push)
assets-dist/
# content-hashed combat models pulled from S3 (in-git primitives have no hash → not matched)
client/assets/ships/*.*.glb
# content-hashed SFX mp3s pulled from S3 (sfx manifest holds the hashed URLs; bytes stay out of git)
client/assets/sounds/*.*.mp3
# content-hashed input-replay traces (intro cutscene) pulled from S3 (the seed holds the hashed URL)
client/assets/recordings/*.json

# Logs
*.log
npm-debug.log*

# Environment / secrets
.env
.env.*

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
